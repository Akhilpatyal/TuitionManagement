datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  INSTITUTE_OWNER
  ADMIN
  TEACHER
  STUDENT
}

enum FeeStatus {
  PAID
  UNPAID
  PENDING
}

enum QuizType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  CASE_STUDY
  ASSERTION_REASON
}

model Institute {
  id           String          @id @default(uuid())
  name         String
  slug         String          @unique
  logoUrl      String?
  primaryColor String?
  status       String          @default("ACTIVE") // ACTIVE | SUSPENDED
  createdAt    DateTime        @default(now())

  users         User[]
  students      Student[]
  attendances   Attendance[]
  feeHistory    FeeHistory[]
  quizzes       Quiz[]
  quizAttempts  QuizAttempt[]
  materials     StudyMaterial[]
  notifications Notification[]
  aiReports     AIReport[]
  doubtPosts    DoubtPost[]
  doubtReplies  DoubtReply[]
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String
  role        Role       @default(STUDENT)
  name        String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  student     Student?
  instituteId String?    // null for SUPER_ADMIN (platform owner, not tied to an institute)
  institute   Institute? @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model Student {
  id             String         @id @default(uuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNumber     String         @unique
  class          String
  batch          String
  subjects       String[]
  parentContact  String
  attendancePct  Float          @default(0.0)
  feeStatus      FeeStatus      @default(UNPAID)
  monthlyFee     Float          @default(0)
  rank           Int            @default(0)
  accuracyPct    Float          @default(0.0)
  xpPoints       Int            @default(0)
  quizStreak     Int            @default(0)
  badges         String[]
  attendances    Attendance[]
  feeHistory     FeeHistory[]
  quizAttempts   QuizAttempt[]
  notifications  Notification[]
  aiReports      AIReport[]
  quizzes        Quiz[]
  doubtPosts     DoubtPost[]
  instituteId    String
  institute      Institute      @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    Boolean  // true = Present, false = Absent
  createdAt DateTime @default(now())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
}

model FeeHistory {
  id         String    @id @default(uuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount     Float
  month      String    // e.g. "May 2026"
  dueDate    DateTime
  paidDate   DateTime?
  status     FeeStatus @default(UNPAID)
  receiptUrl String?
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model Quiz {
  id          String        @id @default(uuid())
  title       String
  description String?
  type        QuizType
  batch       String
  subject     String
  durationMin Int
  questions   Json          // JSON array of question objects (Question[])
  difficulty  String        // "EASY", "MEDIUM", "HARD", "ADAPTIVE"
  isAiGenerated Boolean     @default(false)
  sourceFile  String?       // PDF name / Notes title if generated
  createdAt   DateTime      @default(now())
  attempts    QuizAttempt[]
  studentId     String?
  student       Student?      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instituteId   String
  institute     Institute     @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score       Float
  totalQuestions Int
  correctAnswers Int
  accuracyPct Float
  xpGained    Int
  answers     Json     // Selected answers
  completedAt DateTime @default(now())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model StudyMaterial {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileType    String   // "PDF" | "Notes" | "Homework" | "Assignment"
  fileUrl     String?  // null for written notes (content stored inline instead)
  content     String?  // HTML body for notes written in the rich text editor
  subject     String
  batch       String
  uploadedAt  DateTime @default(now())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(uuid())
  studentId   String?  // Null means global announcement
  student     Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  message     String
  read        Boolean  @default(false)
  type        String   // "QUIZ" | "FEE" | "ATTENDANCE" | "SYSTEM"
  createdAt   DateTime @default(now())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model AIReport {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weakTopics  String[]
  strongTopics String[]
  suggestions String[]
  generatedAt DateTime @default(now())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model DoubtPost {
  id          String       @id @default(uuid())
  instituteId String
  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  studentId   String       // author (the student who posted)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  authorName  String
  title       String
  body        String
  subject     String
  batch       String
  resolved    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  replies     DoubtReply[]
}

model DoubtReply {
  id          String    @id @default(uuid())
  doubtId     String
  doubt       DoubtPost @relation(fields: [doubtId], references: [id], onDelete: Cascade)
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  authorName  String
  authorRole  String    // STUDENT | ADMIN | TEACHER
  body        String
  createdAt   DateTime  @default(now())
}
